{
  "app": {
    "name": "DEEZYBALL TV",
    "version": "1.0.0",
    "min_supported_version": "1.0.0"
  },

  "meta": {
    "developer": "DEEZY1INFO",
    "contact_email": "deezy1info@gmail.com",
    "website": "https://DEEZY1INFO.xyz"
  },

  "messages": {
    "welcome": "Welcome to DEEZYBALL TV",
    "announcement": "Live EPL channels are now available!"
  },

  "features": {
    "maintenance_mode": false,
    "force_update": false,
    "search_enabled": true,
    "favorites_enabled": true,
    "downloads_enabled": false,
    "live_matches_enabled": true,
    "live_scores_enabled": true
  },

  "playlists": {
    "primary": "https://raw.githubusercontent.com/Deezy1info2/exo-tv-data/main/channels.m3u",
    "backup": "https://raw.githubusercontent.com/Deezy1info2/exo-tv-data/main/backup.m3u"
  },

  "matches": {
    "enabled": true,
    "source_url": "https://raw.githubusercontent.com/Deezy1info2/Matches/main/matches.json",
    "refresh_interval_seconds": 60,

    "card_style": {
      "show_competition": true,
      "show_team_logos": true,
      "show_live_badge": true,
      "show_match_time": true,
      "layout": "home_vs_away"
    }
  },

  "live_scores": {
    "enabled": true,
    "provider": "api-sports",

    "source_url": "https://raw.githubusercontent.com/Deezy1info2/Live_scores/main/live_scores.json",

    "api": {
      "base_url": "https://v3.football.api-sports.io",
      "endpoint": "/fixtures",
      "headers": {
        "x-apisports-key": "dba3a616d2f0145456bc296ba3594b8c"
      },
      "query": {
        "live": "all"
      }
    },

    "refresh_interval_seconds": 30,
    "show_logos": true,
    "language": "en",
    "theme": "dark"
  },

  "ads": {
    "ads_enabled": true,
    "banner_enabled": true,
    "interstitial_enabled": true,
    "interstitial_frequency": 4,

    "admob": {
      "app_id": "ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX",
      "banner_ad_unit_id": "ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX",
      "interstitial_ad_unit_id": "ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX",
      "rewarded_ad_unit_id": "ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX"
    }
  },

  "ui": {
    "theme": "dark",
    "primary_color": "#010093",
    "accent_color": "#00e676",
    "show_logo": true,
    "show_channel_logos": true,

    "bottom_navigation": {
      "enabled": true,

      "tabs": [
        {
          "id": "scores",
          "title": "Live Scores",
          "icon": "scoreboard"
        },
        {
          "id": "matches",
          "title": "Matches",
          "icon": "sports_soccer"
        },
        {
          "id": "channels",
          "title": "Channels",
          "icon": "live_tv"
        }
      ]
    }
  },

  "splash": {
    "duration_ms": 2000,
    "background_loading": true,
    "animation": "fade_zoom"
  },

  "loading": {
    "show_text_steps": false,
    "background_fetch": true,
    "cache_first": true
  },

  "player": {
    "auto_play": true,
    "show_controls": true,
    "enable_pip": true,
    "retry_on_error": true,
    "retry_count": 5,
    "buffer_time_ms": 5000,
    "show_buffering_text": false,
    "controls_style": "minimal",
    "show_download_button": true
  },

  "network": {
    "timeout_seconds": 15,
    "retry_count": 5,
    "cache_enabled": true
  },

  "support": {
    "email": "deezy1info@gmail.com",
    "telegram": "https://t.me/+RATFFC0ypbo4ZTc0",
    "whatsapp": "https://whatsapp.com/channel/0029Vb6OS59B4hdbBPBc372E"
  }
}
